PORT=8000
JWT_SECRET=change-me-to-a-long-random-string

# Option A: paste a connection string directly
# DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX.region.aws.neon.tech/neondb?sslmode=require

# Option B: use Neon GitHub integration secrets (recommended if repo is connected)
# Neon adds NEON_API_KEY + NEON_PROJECT_ID to GitHub automatically.
# For local dev, copy those values here or set DATABASE_URL instead.
NEON_PROJECT_ID=super-queen-85743129
NEON_API_KEY=your-neon-api-key
# NEON_DATABASE_NAME=neondb
# NEON_ROLE_NAME=neondb_owner

# Leave both DATABASE_URL and NEON_* unset to use local SQLite at ../data/sprites.db
