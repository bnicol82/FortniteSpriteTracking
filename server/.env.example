PORT=8000
JWT_SECRET=change-me-to-a-long-random-string

# Neon Postgres (recommended for production)
# From https://console.neon.tech/app/projects/super-queen-85743129
# Dashboard → Connect → copy the connection string
DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require

# Leave DATABASE_URL unset to use local SQLite at ../data/sprites.db instead
